@model List<User>
@{
    ViewData["Title"] = "Quản lý Tài khoản";
    var adminEmail = Context.Session.GetString("AdminEmail");
}

<div class="page-header">
  <h1 class="page-title">Quản lý Tài khoản</h1>
</div>

<div class="card" style="margin-bottom: 1rem;">
  <div class="card-header">
    <h3 class="card-title">Tạo tài khoản mới</h3>
  </div>
  <form method="post" action="/admin/users/create" class="grid grid-cols-3" style="gap: 1rem; align-items: end;">
    <div class="form-group">
      <label class="form-label">Username</label>
      <input type="text" name="username" class="form-input" required />
    </div>
    <div class="form-group">
      <label class="form-label">Email</label>
      <input type="email" name="email" class="form-input" required />
    </div>
    <div class="form-group">
      <label class="form-label">Tên hiển thị</label>
      <input type="text" name="fullName" class="form-input" />
    </div>
    <div>
      <button type="submit" class="btn btn-primary">Tạo mới</button>
    </div>
  </form>
  <p class="text-sm text-muted" style="margin-top: 0.75rem;">Mật khẩu mặc định: <strong>TD@12345</strong></p>
</div>

@if (TempData["Success"] != null)
{ 
  <div class="alert alert-success">@TempData["Success"]</div> 
}
@if (TempData["Error"] != null) 
{ 
  <div class="alert alert-danger">@TempData["Error"]</div> 
}

@if (!Model.Any())
{
  <div class="empty-state">
    <div style="font-size: 3rem; margin-bottom: 0.75rem;">👥</div>
    <p>Chưa có tài khoản nào</p>
  </div>
}
else
{
  <div class="table-wrapper">
    <table class="table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Tên</th>
          <th>Vai trò</th>
          <th>Ngày tạo</th>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var user in Model)
        {
          <tr>
            <td>@user.Username</td>
            <td>@user.Email</td>
            <td>@user.FullName</td>
            <td>
              <span class="badge badge-primary">Người dùng</span>
            </td>
            <td class="text-muted">@user.CreatedAt.ToString("yyyy-MM-dd")</td>
            <td>
              <div class="action-buttons">
                <form method="post" action="/admin/users/reset-password">
                  <input type="hidden" name="userId" value="@user.Id" />
                  <button type="submit" class="action-btn" onclick="return confirm('Reset mật khẩu cho @user.Username về TD@12345?')">🔑</button>
                </form>
                <form method="post" action="/admin/users/delete">
                  <input type="hidden" name="userId" value="@user.Id" />
                  <button type="submit" class="action-btn action-btn-danger" onclick="return confirm('Xóa tài khoản @user.Username?')">🗑️</button>
                </form>
              </div>
            </td>
          </tr>
        }
      </tbody>
    </table>
  </div>
}
