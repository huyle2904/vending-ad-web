@model List<Device>
@{
    ViewData["Title"] = "Bảng điều khiển";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Bảng điều khiển thiết bị</h1>
    <p class="text-muted">Trạng thái thời gian thực của tất cả thiết bị đã đăng ký</p>
  </div>
</div>

@{
    var online  = Model.Count(d => d.LastSeen.HasValue && (DateTime.UtcNow - d.LastSeen.Value).TotalMinutes < 5);
    var offline = Model.Count - online;
}

<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-value">@Model.Count</div>
    <div class="stat-label">Tổng thiết bị</div>
  </div>
  <div class="stat-card">
    <div class="stat-value stat-success">@online</div>
    <div class="stat-label">Online</div>
  </div>
  <div class="stat-card">
    <div class="stat-value stat-danger">@offline</div>
    <div class="stat-label">Offline</div>
  </div>
</div>

<div class="table-wrapper">
  @if (!Model.Any())
  {
    <div class="empty-state">
      <div style="font-size: 2.5rem; margin-bottom: 0.75rem;">📟</div>
      <p>Chưa có thiết bị nào được đăng ký.</p>
      <p class="text-sm text-muted">Thiết bị sẽ xuất hiện tự động sau lần heartbeat đầu tiên.</p>
    </div>
  }
  else
  {
    <table class="table">
      <thead>
        <tr>
          <th>Trạng thái</th>
          <th>Mã thiết bị</th>
          <th>Media đã gán</th>
          <th>Lần cuối hoạt động (UTC)</th>
        </tr>
      </thead>
      <tbody>
        @foreach (var device in Model)
        {
          var isOnline = device.LastSeen.HasValue &&
                         (DateTime.UtcNow - device.LastSeen.Value).TotalMinutes < 5;
          var campaign = device.Campaigns.FirstOrDefault();

          <tr>
            <td>
              @if (isOnline)
              {
                <span class="badge badge-success">
                  <span class="status-dot status-online" style="animation: blink 1.8s ease-in-out infinite;"></span>Online
                </span>
              }
              else
              {
                <span class="badge badge-danger">
                  <span class="status-dot status-offline"></span>Offline
                </span>
              }
            </td>
            <td><strong style="color: var(--primary); font-family: monospace;">@device.DeviceCode</strong></td>
            <td class="text-muted">
              @if (campaign?.Media != null)
              {
                @campaign.Media.FileName
              }
              else
              {
                <span style="font-style: italic;">— chưa gán media —</span>
              }
            </td>
            <td class="text-muted text-sm">
              @(device.LastSeen.HasValue
                ? device.LastSeen.Value.ToString("yyyy-MM-dd HH:mm:ss")
                : "Chưa bao giờ")
            </td>
          </tr>
        }
      </tbody>
    </table>
  }
</div>

<p class="text-sm text-muted" style="margin-top: 1rem; text-align: right;">
  🟢 Online = heartbeat trong vòng 5 phút · Tự động cập nhật mỗi 30s
</p>

<style>
  @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.25} }
</style>

<script>
  setTimeout(() => location.reload(), 30_000);
</script>
