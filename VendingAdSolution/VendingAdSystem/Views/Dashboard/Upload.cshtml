@{
    ViewData["Title"] = "Upload Media";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Tải lên Media</h1>
    <p class="text-muted">Gán file video vào thiết bị</p>
  </div>
</div>

<div class="card" style="max-width: 500px;">
  <div class="form-group">
    <label class="form-label">Mã thiết bị</label>
    <input type="text" id="deviceCode" class="form-input" placeholder="VD: TABLET-001" />
  </div>

  <div class="form-group">
    <label class="form-label">Video File</label>
    <div class="upload-area" id="dropZone">
      <input type="file" id="videoFile" accept="video/*" onchange="onFileChange(this)" />
      <div style="font-size: 1.75rem; margin-bottom: 0.5rem;">🎬</div>
      <p class="text-muted">Click hoặc kéo file vào đây</p>
      <p id="fileName" style="color: var(--primary); font-size: 0.8125rem; margin-top: 0.375rem;"></p>
    </div>
  </div>

  <div id="progressBar" style="background: var(--border); border-radius: 4px; height: 4px; margin-top: 1.25rem; overflow: hidden; display: none;">
    <div id="progressFill" style="height: 100%; background: var(--primary); width: 0; transition: width 0.2s; border-radius: 4px;"></div>
  </div>

  <button id="uploadBtn" class="btn btn-primary btn-block" onclick="doUpload()">Tải lên & Gán →</button>
  <div id="alert" class="alert" style="display: none; margin-top: 1.25rem;"></div>
</div>

<script>
function onFileChange(input) {
  const name = input.files[0]?.name;
  document.getElementById('fileName').textContent = name ?? '';
}

async function doUpload() {
  const code  = document.getElementById('deviceCode').value.trim();
  const file  = document.getElementById('videoFile').files[0];
  const btn   = document.getElementById('uploadBtn');
  const alert = document.getElementById('alert');
  const bar   = document.getElementById('progressBar');
  const fill  = document.getElementById('progressFill');

  if (!code)  { showAlert('err', 'Vui lòng nhập mã thiết bị.'); return; }
  if (!file)  { showAlert('err', 'Vui lòng chọn file video.'); return; }

  btn.disabled = true;
  btn.textContent = 'Đang tải lên…';
  alert.style.display = 'none';
  bar.style.display = 'block';
  fill.style.width = '0%';

  const fd = new FormData();
  fd.append('file', file);
  fd.append('deviceCode', code);

  return new Promise((resolve) => {
    const xhr = new XMLHttpRequest();
    xhr.open('POST', '/api/media/upload');

    xhr.upload.onprogress = (e) => {
      if (e.lengthComputable) {
        fill.style.width = Math.round(e.loaded / e.total * 100) + '%';
      }
    };

    xhr.onload = () => {
      btn.disabled = false;
      btn.textContent = 'Tải lên & Gán →';
      bar.style.display = 'none';
      try {
        const data = JSON.parse(xhr.responseText);
        if (xhr.status === 200) {
          showAlert('ok', `✓ "${data.fileName}" đã gán cho ${data.deviceCode}`);
          document.getElementById('videoFile').value = '';
          document.getElementById('fileName').textContent = '';
        } else {
          showAlert('err', '✗ ' + (data.message ?? 'Tải lên thất bại'));
        }
      } catch {
        showAlert('err', '✗ Phản hồi máy chủ không hợp lệ');
      }
      resolve();
    };

    xhr.onerror = () => {
      btn.disabled = false;
      btn.textContent = 'Tải lên & Gán →';
      bar.style.display = 'none';
      showAlert('err', '✗ Lỗi mạng — máy chủ có đang chạy không?');
      resolve();
    };

    xhr.send(fd);
  });
}

function showAlert(type, msg) {
  const el = document.getElementById('alert');
  el.className = 'alert ' + (type === 'ok' ? 'alert-success' : 'alert-danger');
  el.textContent = msg;
  el.style.display = 'block';
}
</script>
