@using VendingAdSystem.Application.DTOs
@model DashboardViewModel
@{
    ViewData["Title"] = "Bảng điều khiển";
    var hasNowPlaying = Model.NowPlaying is { IsEmpty: false };
    var hasUpcoming = Model.Upcoming is { IsEmpty: false };
}

<div class="dashboard-page">
    <section class="dashboard-command-row">
        <div class="dashboard-date-chip"><i class="bi bi-calendar2-week"></i>@Model.DateFilterLabel</div>
        <div class="dashboard-hero-actions">
            <a class="btn-soft" href="/portal/schedules"><i class="bi bi-calendar-plus"></i>Tạo lịch phát</a>
            <a class="btn-soft" href="/portal/videos"><i class="bi bi-cloud-upload"></i>Tải video</a>
        </div>
    </section>

    @await Html.PartialAsync("~/Views/Shared/Components/_KpiCards.cshtml", Model.Kpis)

    <section class="dashboard-section-heading">
        <div>
            <h2>Lịch phát</h2>
            <p>@(hasNowPlaying || hasUpcoming ? "Theo dõi nội dung đang chạy và lịch phát kế tiếp." : "Chưa có lịch phát đang chạy hoặc sắp phát.")</p>
        </div>
        <a class="section-link" href="/portal/schedules">Quản lý lịch phát <i class="bi bi-arrow-right"></i></a>
    </section>

    <section class="schedule-grid">
        @await Html.PartialAsync("~/Views/Shared/Components/_NowPlaying.cshtml", Model.NowPlaying)
        @await Html.PartialAsync("~/Views/Shared/Components/_Upcoming.cshtml", Model.Upcoming)
    </section>

    @await Html.PartialAsync("~/Views/Shared/Components/_DeviceGrid.cshtml", Model.Devices)
</div>
