@using VendingAdSystem.Controllers
@{
    var groupedCampaigns = (List<DevicePlaylistGroup>)ViewBag.GroupedCampaigns;
    ViewData["Title"] = "Manage Playlist";
}

<div class="page-header">
  <div>
    <h1 class="page-title">Quản lý Playlist</h1>
    <p class="text-muted">Kéo và thả để sắp xếp lại video cho từng thiết bị</p>
  </div>
</div>

<div class="alert alert-success" id="successMsg" style="display: none;">Thứ tự playlist đã được lưu!</div>

<div class="card" style="margin-bottom: 1.5rem;">
<p style="color: var(--primary); font-size: 0.875rem;">
      💡 Video được hiển thị theo thứ tự phát. Kéo để sắp xếp lại. Thay đổi được lưu khi bạn nhấn "Lưu thứ tự".
    </p>
</div>

@if (groupedCampaigns == null || !groupedCampaigns.Any())
{
<div class="empty-state">
      <div style="font-size: 3rem; margin-bottom: 1rem;">📋</div>
      <p>Không tìm thấy chiến dịch hoạt động nào.</p>
      <p class="text-sm text-muted">Tải lên video và gán cho thiết bị để hiển thị tại đây.</p>
      <a href="/portal/videos" class="btn btn-primary" style="margin-top: 1rem;">Đến Video</a>
    </div>
}
else
{
  @foreach (var group in groupedCampaigns)
  {
    var device = group.Device;
    var videos = group.Videos;
    
    <div class="card" style="margin-bottom: 1.5rem;">
      <div class="flex items-center justify-between" style="padding-bottom: 1rem; border-bottom: 1px solid var(--border); margin-bottom: 1rem;">
        <div>
          <span style="color: var(--primary); font-weight: 600;">@device.DeviceCode</span>
          <span class="text-muted text-sm" style="margin-left: 0.5rem;">@device.Location</span>
        </div>
        <span class="badge badge-secondary">@videos.Count video</span>
      </div>
      
      <div class="video-list" data-device-id="@device.Id" style="min-height: 100px;">
        @if (!videos.Any())
        {
          <div class="text-center text-muted" style="padding: 1.5rem; border: 1px dashed var(--border); border-radius: var(--radius);">
            Chưa có video nào được gán cho thiết bị này
          </div>
        }
        else
        {
          @foreach (var campaign in videos.OrderBy(c => c.OrderIndex))
          {
            <div class="video-item" draggable="true" data-campaign-id="@campaign.Id" 
                 style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 1rem; background: var(--muted); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 0.5rem; cursor: grab; transition: border-color 0.15s;">
              <span style="color: var(--muted-foreground); font-size: 1.125rem; cursor: grab;">☰</span>
              <span style="background: rgba(37,99,235,0.1); color: var(--primary); width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700;">@(campaign.OrderIndex + 1)</span>
              <span style="font-size: 1.5rem;">🎬</span>
              <div style="flex: 1;">
                <div style="font-size: 0.875rem;">@campaign.Media.FileName</div>
                <div class="text-sm text-muted">@campaign.StartDate?.ToString("MMM dd") - @campaign.EndDate?.ToString("MMM dd, yyyy")</div>
              </div>
            </div>
          }
        }
      </div>
    </div>
  }

  <div class="text-center" style="margin-top: 1.5rem;">
    <button class="btn btn-primary" onclick="saveOrder()">Lưu thứ tự</button>
  </div>
}

<style>
  .video-item:hover { border-color: var(--primary) !important; }
  .video-item.dragging { opacity: 0.5; transform: scale(0.98); }
</style>

<script>
  let draggedItem = null;

  document.querySelectorAll('.video-item').forEach(item => {
    item.addEventListener('dragstart', function(e) {
      draggedItem = this;
      this.classList.add('dragging');
      e.dataTransfer.effectAllowed = 'move';
    });

    item.addEventListener('dragend', function() {
      this.classList.remove('dragging');
      draggedItem = null;
      updateOrderNumbers();
    });

    item.addEventListener('dragover', function(e) {
      e.preventDefault();
      e.dataTransfer.dropEffect = 'move';
    });

    item.addEventListener('drop', function(e) {
      e.preventDefault();
      if (draggedItem && draggedItem !== this) {
        const container = this.parentNode;
        const items = Array.from(container.querySelectorAll('.video-item'));
        const fromIndex = items.indexOf(draggedItem);
        const toIndex = items.indexOf(this);
        
        if (fromIndex < toIndex) {
          container.insertBefore(draggedItem, this.nextSibling);
        } else {
          container.insertBefore(draggedItem, this);
        }
        updateOrderNumbers();
      }
    });
  });

  function updateOrderNumbers() {
    document.querySelectorAll('.video-list').forEach(list => {
      const items = list.querySelectorAll('.video-item');
      items.forEach((item, index) => {
        item.querySelectorAll('span')[1].textContent = index + 1;
      });
    });
  }

  async function saveOrder() {
    const updates = [];
    
    document.querySelectorAll('.video-list').forEach(list => {
      const deviceId = list.dataset.deviceId;
      const items = list.querySelectorAll('.video-item');
      items.forEach((item, index) => {
        updates.push({
          campaignId: parseInt(item.dataset.campaignId),
          orderIndex: index
        });
      });
    });

    try {
      const response = await fetch('/portal/playlist/update-order', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(updates)
      });

      if (response.ok) {
        document.getElementById('successMsg').style.display = 'block';
        setTimeout(() => {
          document.getElementById('successMsg').style.display = 'none';
        }, 3000);
      } else {
        alert('Lưu thứ tự thất bại');
      }
    } catch (e) {
      alert('Lỗi khi lưu thứ tự');
    }
  }
</script>
