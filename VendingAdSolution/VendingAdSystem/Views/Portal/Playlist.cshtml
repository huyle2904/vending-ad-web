@model List<Playlist>
@{
    var medias = (List<Media>)ViewBag.Medias;
    ViewData["Title"] = "Danh sách phát";
    var totalVideos = Model.Sum(p => p.Items.Count);
}

<div class="playlist-page">
  <section class="playlist-overview">
    <div class="playlist-create-card playlist-create-card-modern">
      <div class="playlist-create-head">
        <span class="playlist-create-icon"><i class="bi bi-play-fill"></i></span>
        <div>
          <h3>Tạo playlist mới</h3>
          <p>Chuẩn bị mẫu nội dung để dùng lại khi lên lịch phát.</p>
        </div>
      </div>
      <form method="post" action="/portal/playlist/create" class="playlist-create-form playlist-create-form-modern">
        @Html.AntiForgeryToken()
        <input id="playlistNameInput" type="text" name="name" value="@ViewBag.PlaylistDraftName" placeholder="Nhập tên playlist mới..." required />
        <button type="submit"><i class="bi bi-plus-lg"></i>Tạo playlist</button>
      </form>
    </div>

    <div class="playlist-metric-grid">
      <article class="playlist-metric-card">
        <span><i class="bi bi-collection-play"></i></span>
        <div><strong>@Model.Count</strong><small>Tổng playlist</small></div>
      </article>
      <article class="playlist-metric-card">
        <span><i class="bi bi-collection"></i></span>
        <div><strong>@totalVideos</strong><small>Tổng video</small></div>
      </article>
    </div>
  </section>

  @if (Model == null || !Model.Any())
  {
    <section class="playlist-empty-state">
      <div class="playlist-empty-icon"><i class="bi bi-collection-play"></i></div>
      <h2>Chưa có playlist nào</h2>
      <p>Tạo playlist rồi thêm video từ kho video.</p>
      <a href="/portal/videos" class="video-upload-btn playlist-empty-cta">Đến kho video</a>
      <div class="playlist-tip-box">
        <strong>Gợi ý</strong>
        <span>Bạn có thể tạo nhiều playlist cho các mục đích khác nhau như: quảng cáo, khuyến mãi, sự kiện, giờ vàng...</span>
      </div>
    </section>
  }
  else
  {
    <section class="playlist-library-card">
      <header class="playlist-library-head">
        <div>
          <h2>Playlist đang có</h2>
          <p>Kéo thả video trong từng playlist rồi lưu lại thứ tự phát.</p>
        </div>
        <button class="video-upload-btn playlist-save-btn" onclick="saveOrder()"><i class="bi bi-save"></i>Lưu thứ tự</button>
      </header>

      <div class="playlist-list-grid">
        @foreach (var playlist in Model)
        {
          var items = playlist.Items.OrderBy(i => i.OrderIndex).ToList();
          <article class="playlist-item-card playlist-item-card-modern">
            <header>
              <div class="playlist-title-group">
                <span class="playlist-card-icon"><i class="bi bi-music-note-list"></i></span>
                <div>
                  <h3>@playlist.Name</h3>
                  <p>@items.Count video trong mẫu nội dung này</p>
                </div>
              </div>
              <div class="playlist-item-tools">
                <span class="pill-counter"><i class="bi bi-play-circle"></i>@items.Count video</span>
                <button type="button" class="btn-soft fx-soft" onclick="openVideoModal(@playlist.Id)"><i class="bi bi-plus-circle"></i>Thêm video</button>
                <form method="post" action="/portal/playlist/delete" onsubmit="return confirm('Xóa playlist @playlist.Name?')">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="playlistId" value="@playlist.Id" />
                  <button type="submit" class="btn-soft danger"><i class="bi bi-trash"></i>Xóa</button>
                </form>
              </div>
            </header>

            @if (!items.Any())
            {
              <div class="empty-box playlist-empty-min"><i class="bi bi-collection-play"></i><span>Danh sách phát chưa có video.</span></div>
            }
            else
            {
              <div class="playlist-media-list" data-playlist-id="@playlist.Id">
                @foreach (var item in items)
                {
                  <div class="playlist-media-row" draggable="true" data-playlist-item-id="@item.Id">
                    <span class="drag" aria-label="Kéo để đổi thứ tự"><i class="bi bi-grip-vertical"></i></span>
                    <span class="index">@(item.OrderIndex + 1)</span>
                    <span class="name"><i class="bi bi-film"></i>@item.Media.FileName</span>
                    <span class="size">@((item.Media.FileSize / 1024 / 1024).ToString()) MB</span>
                    <form method="post" action="/portal/playlist/remove-item" onsubmit="return confirm('Xóa video này khỏi playlist?')">
                      @Html.AntiForgeryToken()
                      <input type="hidden" name="playlistItemId" value="@item.Id" />
                      <button type="submit" class="btn-soft danger"><i class="bi bi-trash"></i>Xóa</button>
                    </form>
                  </div>
                }
              </div>
            }
          </article>
        }
      </div>
    </section>
  }
</div>

<div class="modal-overlay u-hidden" id="videoModal">
  <div class="modal modal-wide detail-modal playlist-video-modal">
    <div class="detail-modal-header">
      <div class="detail-title-group">
        <span class="detail-title-icon schedule"><i class="bi bi-plus-circle"></i></span>
        <div>
          <div class="modal-title">Thêm video từ thư viện</div>
          <p class="detail-subtitle">Chọn một hoặc nhiều video đã upload.</p>
        </div>
      </div>
      <button class="modal-close" type="button" onclick="closeVideoModal()" aria-label="Đóng"><i class="bi bi-x-lg"></i></button>
    </div>
    <form method="post" action="/portal/playlist/add-video">
      @Html.AntiForgeryToken()
      <input type="hidden" name="playlistId" id="modalPlaylistId" />
      <div class="modal-body">
        @if (!medias.Any())
        {
          <div class="detail-empty-state"><i class="bi bi-collection-play"></i><span>Chưa có video trong thư viện.</span></div>
        }
        else
        {
          <div class="playlist-video-picker">
            @foreach (var media in medias)
            {
              <label class="playlist-video-option">
                <input type="checkbox" name="mediaIds" value="@media.Id" />
                <span class="playlist-video-option-icon"><i class="bi bi-film"></i></span>
                <span>
                  <strong>@media.FileName</strong>
                  <small>@(media.FileSize / 1024 / 1024) MB</small>
                </span>
              </label>
            }
          </div>
        }
      </div>
      <div class="playlist-modal-actions">
        <button type="button" class="btn btn-secondary fx-soft" onclick="closeVideoModal()">Hủy</button>
        <button type="submit" class="btn btn-primary fx-btn"><i class="bi bi-plus-lg"></i>Thêm video</button>
      </div>
    </form>
  </div>
</div>

<script>
  let draggedItem = null;
  function showModalAtViewportCenter(modalId) {
    const modal = document.getElementById(modalId);
    if (!modal) return;

    if (modal.parentElement !== document.body) {
      document.body.appendChild(modal);
    }

    modal.classList.remove('u-hidden');
    modal.style.position = 'fixed';
    modal.style.inset = '0';
    modal.style.width = '100vw';
    modal.style.height = '100vh';
    modal.style.display = 'flex';
    modal.style.alignItems = 'center';
    modal.style.justifyContent = 'center';
    modal.style.zIndex = '1200';
  }

  function openVideoModal(playlistId) {
    document.getElementById('modalPlaylistId').value = playlistId;
    showModalAtViewportCenter('videoModal');
  }

  function closeVideoModal() {
    const modal = document.getElementById('videoModal');
    if (modal) modal.style.display = 'none';
  }
  document.querySelectorAll('.playlist-media-row').forEach(item=>{
    item.addEventListener('dragstart', function(e){ draggedItem=this; this.classList.add('dragging'); e.dataTransfer.effectAllowed='move';});
    item.addEventListener('dragend', function(){ this.classList.remove('dragging'); draggedItem=null; updateOrderNumbers();});
    item.addEventListener('dragover', function(e){ e.preventDefault();});
    item.addEventListener('drop', function(e){ e.preventDefault(); if(draggedItem&&draggedItem!==this){ const c=this.parentNode; const items=Array.from(c.querySelectorAll('.playlist-media-row')); const from=items.indexOf(draggedItem); const to=items.indexOf(this); if(from<to){c.insertBefore(draggedItem,this.nextSibling);}else{c.insertBefore(draggedItem,this);} updateOrderNumbers(); }});
  });
  function updateOrderNumbers(){ document.querySelectorAll('.playlist-media-list').forEach(list=>{ list.querySelectorAll('.playlist-media-row').forEach((item,i)=>{ item.querySelector('.index').textContent=i+1; }); }); }
  async function saveOrder(){
    const lists=document.querySelectorAll('.playlist-media-list');
    for(const list of lists){
      const updates=[]; list.querySelectorAll('.playlist-media-row').forEach((item,i)=>updates.push({playlistItemId:parseInt(item.dataset.playlistItemId),orderIndex:i}));
      const resp=await fetch('/portal/playlist/update-order',{method:'POST',headers:{'Content-Type':'application/json','RequestVerificationToken':window.getRequestVerificationToken?.() || ''},body:JSON.stringify({playlistId:parseInt(list.dataset.playlistId),updates})});
      if(!resp.ok){ window.showToast('Lưu thứ tự thất bại','error'); return; }
    }
    window.showToast('Thứ tự playlist đã được lưu!','success');
  }
</script>
