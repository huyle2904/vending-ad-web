@model List<Media>
@{
    ViewData["Title"] = "Thư viện video";
    const string videoPlaceholder = "/images/video-placeholder.svg";
    var totalSizeMb = Model.Sum(v => v.FileSize) / 1024 / 1024;
    var videoQuery = ViewBag.VideoQuery as string ?? string.Empty;
    var videoSortBy = ViewBag.VideoSortBy as string ?? "uploadedAt";
    var videoSortDir = ViewBag.VideoSortDir as string ?? "desc";
}

<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="video-page">
  <section class="video-overview">
    <div class="video-drop-area" id="dropZone" role="button" tabindex="0" aria-label="Tải video lên thư viện" onclick="openVideoPicker(event)" onkeydown="onDropZoneKeydown(event)" ondragover="onDropDragOver(event)" ondragleave="onDropDragLeave(event)" ondrop="onDropFile(event)">
      <input type="file" id="videoFile" accept="video/*" onchange="onFileSelect(this)" hidden />
      <div class="upload-circle"><i class="bi bi-cloud-arrow-up-fill"></i></div>
      <div class="video-drop-copy">
        <h3>Kéo & thả video vào đây</h3>
        <p>Tải video lên thư viện để dùng cho playlist và lịch phát.</p>
        <div class="video-format-chips">
          <span>MP4</span>
          <span>AVI</span>
          <span>MOV</span>
          <span>Tối đa 50MB</span>
        </div>
      </div>
      <div class="video-drop-actions">
        <button type="button" class="video-select-btn" onclick="openVideoPicker(event)"><i class="bi bi-folder2-open"></i>Chọn file</button>
        <small>hoặc thả file vào vùng này</small>
      </div>
      <p id="fileName" class="media-selected-file"></p>
      <div id="uploadLoading" class="upload-loading u-hidden" style="display:none" aria-live="polite"><span class="upload-spinner"></span><span>Đang tải video...</span></div>
    </div>

    <div class="video-stat-actions video-metric-grid">
      <article class="video-metric-card">
        <span><i class="bi bi-collection-play"></i></span>
        <div><strong>@Model.Count</strong><small>Tổng video</small></div>
      </article>
      <article class="video-metric-card">
        <span><i class="bi bi-sd-card"></i></span>
        <div><strong>@totalSizeMb MB</strong><small>Tổng dung lượng</small></div>
      </article>
    </div>
  </section>

  <section class="video-library-card">
    <header class="video-library-head">
      <div>
        <h2>Danh sách video (@Model.Count)</h2>
        <p>Dùng xóa hàng loạt khi cần chọn nhiều video cùng lúc.</p>
      </div>
      <div class="video-tools">
        <form method="get" action="/portal/videos" id="videoFilterForm" class="video-tools" style="gap:.6rem;">
          <div class="search-box"><i class="bi bi-search"></i><input type="text" name="q" value="@videoQuery" placeholder="Tìm kiếm video..." /></div>
          <select class="btn-soft fx-soft" name="sortBy" onchange="document.getElementById('videoFilterForm').submit()">
            <option value="uploadedAt" selected="@(videoSortBy == "uploadedat")">Ngày tải lên</option>
            <option value="fileName" selected="@(videoSortBy == "filename")">Tên video</option>
            <option value="fileSize" selected="@(videoSortBy == "filesize")">Dung lượng</option>
          </select>
          <select class="btn-soft fx-soft" name="sortDir" onchange="document.getElementById('videoFilterForm').submit()">
            <option value="desc" selected="@(videoSortDir == "desc")">Giảm dần</option>
            <option value="asc" selected="@(videoSortDir == "asc")">Tăng dần</option>
          </select>
          <button type="submit" class="u-hidden" aria-hidden="true">submit</button>
        </form>
        <button class="btn-soft danger" type="button" id="toggleDeleteModeBtn" onclick="startBatchDeleteMode()" disabled="@(!Model.Any())"><i class="bi bi-trash3"></i>Xóa hàng loạt</button>
        <div id="deleteActions" class="bulk-delete-actions" aria-live="polite">
          <span id="selectedDeleteCount" class="bulk-delete-count">0 video đã chọn</span>
          <button type="button" class="btn-soft fx-soft" onclick="cancelDeleteMode()">Hủy</button>
          <button type="button" class="btn-soft danger" onclick="confirmBatchDelete()"><i class="bi bi-trash3"></i>Xóa</button>
        </div>
      </div>
    </header>

    @if (!Model.Any())
    {
      <div class="empty-box video-empty-min">Chưa có video nào trong thư viện.</div>
    }
    else
    {
      <div class="video-list">
          @foreach (var video in Model)
          {
            var playlists = video.PlaylistItems.Select(i => i.Playlist).DistinctBy(p => p.Id).ToList();
            <article class="video-list-row fx-list-row" onclick="toggleRowSelection(event, this)">
              <div class="col-check delete-col">
                <label class="bulk-check" title="Chọn video để xóa hàng loạt" onclick="event.stopPropagation()">
                  <input type="checkbox" class="delete-check" value="@video.Id" onchange="onDeleteCheckChange(this)" />
                  <span class="bulk-check-box"><i class="bi bi-check2"></i></span>
                </label>
              </div>
              <div class="col-media">
                <img src="@(string.IsNullOrWhiteSpace(video.ThumbnailUrl) ? videoPlaceholder : video.ThumbnailUrl)" onerror="this.onerror=null;this.src='@videoPlaceholder';" alt="thumb" />
                <div>
                  <strong>@video.FileName</strong>
                  <small>Video thư viện</small>
                </div>
              </div>
              <div class="video-row-meta"><strong>@(video.FileSize / 1024 / 1024) MB</strong><small>Dung lượng</small></div>
	              <div class="video-row-meta"><strong>@VietnamTimeFormatter.FormatUtc(video.UploadedAt, "dd/MM/yyyy")</strong><small>Ngày tải lên</small></div>
              <div class="video-row-meta"><strong>@playlists.Count playlist</strong><small>Đang sử dụng</small></div>
              <div class="col-actions">
                <button class="icon-btn" title="Xem"><i class="bi bi-eye"></i></button>
                <form method="post" action="/portal/videos/delete" class="u-inline">
                  @Html.AntiForgeryToken()
                  <input type="hidden" name="videoId" value="@video.Id" />
                  <button class="icon-btn danger-outline" type="submit" title="Xóa video" aria-label="Xóa video @video.FileName" onclick="return confirm('Bạn có chắc muốn xóa video này?')"><i class="bi bi-trash3"></i></button>
                </form>
              </div>
            </article>
          }
      </div>
      <div class="video-list-foot">Hiển thị 1 đến @Model.Count của @Model.Count video</div>
    }
  </section>
</div>

<script>
  const maxUploadBytes = 50 * 1024 * 1024;

  var uploadLoadingEl = document.getElementById('uploadLoading');
  if (uploadLoadingEl) {
    uploadLoadingEl.classList.add('u-hidden');
    uploadLoadingEl.style.display = 'none';
  }

  function openVideoPicker(event) {
    if (event?.target?.id === 'videoFile') return;
    if (event) {
      event.preventDefault();
      event.stopPropagation();
    }
    var dropZone = document.getElementById('dropZone');
    if (dropZone?.classList.contains('uploading')) return;
    document.getElementById('videoFile')?.click();
  }

  function onDropZoneKeydown(event) {
    if (event.key === 'Enter' || event.key === ' ') {
      openVideoPicker(event);
    }
  }

  function onFileSelect(input) {
    var file = input.files[0];
    if (!file) return;
    if (file.type && !file.type.startsWith('video/')) { window.showToast('Chỉ hỗ trợ file video', 'error'); input.value = ''; return; }
    if (file.size > maxUploadBytes) { window.showToast('File phải nhỏ hơn 50MB', 'error'); input.value = ''; return; }
    document.getElementById('fileName').textContent = file.name;
    doUpload();
  }

  function setUploadState(isUploading) {
    var loading = document.getElementById('uploadLoading');
    var dropZone = document.getElementById('dropZone');
    if (loading) {
      loading.classList.toggle('u-hidden', !isUploading);
      loading.style.display = isUploading ? 'flex' : 'none';
    }
    dropZone?.classList.toggle('uploading', isUploading);
  }

  function readUploadError(xhr) {
    if (xhr.status === 401) return 'Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.';
    if (xhr.status === 413) return 'File vượt quá dung lượng 50MB.';
    try {
      var data = xhr.responseText ? JSON.parse(xhr.responseText) : {};
      return data.message || 'Tải lên thất bại';
    } catch {
      return 'Tải lên thất bại';
    }
  }

  async function doUpload() {
    var file = document.getElementById('videoFile').files[0];
    if (!file) return;
    var formData = new FormData();
    formData.append('file', file);
    var xhr = new XMLHttpRequest(); xhr.open('POST', '/api/portal/upload');
    var token = window.getRequestVerificationToken?.() || '';
    if (token) xhr.setRequestHeader('RequestVerificationToken', token);
    setUploadState(true);
    xhr.upload.onprogress = function(e) { };
    xhr.onload = async function(){
      if(xhr.status >= 200 && xhr.status < 300){
        try {
          const res = await fetch(window.location.href, { headers: { 'X-Requested-With': 'XMLHttpRequest' }, credentials: 'same-origin' });
          const html = await res.text();
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const newLibrary = doc.querySelector('.video-library-card');
          const newStats = doc.querySelector('.video-stat-actions');
          if (newLibrary) {
            const currentLibrary = document.querySelector('.video-library-card');
            if (currentLibrary) currentLibrary.replaceWith(newLibrary);
          }
          if (newStats) {
            const currentStats = document.querySelector('.video-stat-actions');
            if (currentStats) currentStats.replaceWith(newStats);
          }
          window.refreshCustomSelects?.();
          resetBatchDeleteMode();
          document.getElementById('videoFile').value = '';
          document.getElementById('fileName').textContent = '';
          window.showToast('Tải lên thành công', 'success');
        } catch {
          window.showToast('Tải lên thành công', 'success');
        }
      } else {
        window.showToast(readUploadError(xhr),'error');
      }
      setUploadState(false);
    };
    xhr.onerror = function(){
      setUploadState(false);
      window.showToast('Lỗi mạng', 'error');
    };
    xhr.onabort = function(){
      setUploadState(false);
    };
    xhr.send(formData);
  }


  function onDropDragOver(event) {
    event.preventDefault();
    document.getElementById('dropZone').classList.add('drag-over');
  }

  function onDropDragLeave(event) {
    event.preventDefault();
    document.getElementById('dropZone').classList.remove('drag-over');
  }

  function onDropFile(event) {
    event.preventDefault();
    document.getElementById('dropZone').classList.remove('drag-over');
    var file = event.dataTransfer?.files?.[0];
    if (!file) return;
    var input = document.getElementById('videoFile');
    var dt = new DataTransfer();
    dt.items.add(file);
    input.files = dt.files;
    onFileSelect(input);
  }

  function startBatchDeleteMode() {
    var card = document.querySelector('.video-library-card');
    if (!card) return;
    card.classList.add('batch-delete-mode');
    updateBatchDeleteCount();
  }

  function cancelDeleteMode() {
    document.querySelectorAll('.delete-check').forEach(cb => cb.checked = false);
    resetBatchDeleteMode();
  }

  function resetBatchDeleteMode() {
    document.querySelector('.video-library-card')?.classList.remove('batch-delete-mode');
    document.querySelectorAll('.video-list-row.selected').forEach(row => row.classList.remove('selected'));
    updateBatchDeleteCount();
  }

  function onDeleteCheckChange(input) {
    input.closest('.video-list-row')?.classList.toggle('selected', input.checked);
    updateBatchDeleteCount();
  }

  function toggleRowSelection(event, row) {
    if (!document.querySelector('.video-library-card')?.classList.contains('batch-delete-mode')) return;
    if (event.target.closest('button, a, input, label, form, .col-actions')) return;
    var checkbox = row.querySelector('.delete-check');
    if (!checkbox) return;
    checkbox.checked = !checkbox.checked;
    onDeleteCheckChange(checkbox);
  }

  function updateBatchDeleteCount() {
    const selected = document.querySelectorAll('.delete-check:checked').length;
    const countEl = document.getElementById('selectedDeleteCount');
    if (countEl) countEl.textContent = selected + ' video đã chọn';
  }

  function confirmBatchDelete() {
    const selected = Array.from(document.querySelectorAll('.delete-check:checked')).map(x => x.value);
    if (!selected.length) { window.showToast('Chọn ít nhất 1 video', 'error'); return; }
    if (!confirm('Xóa ' + selected.length + ' video đã chọn?')) return;
    const form = document.createElement('form'); form.method = 'post'; form.action = '/portal/videos/batch-delete';
    const token = window.getRequestVerificationToken?.() || '';
    if (token) {
      const csrf = document.createElement('input');
      csrf.type = 'hidden';
      csrf.name = '__RequestVerificationToken';
      csrf.value = token;
      form.appendChild(csrf);
    }
    selected.forEach(id => { const i = document.createElement('input'); i.type='hidden'; i.name='videoIds'; i.value=id; form.appendChild(i); });
    document.body.appendChild(form); form.submit();
  }
</script>
