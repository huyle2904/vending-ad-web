@model List<Device>
@{ 
    var totalDevices = Convert.ToInt32(ViewBag.TotalDevices ?? Model.Count);
    var onlineCount = Convert.ToInt32(ViewBag.OnlineCount ?? 0);
    var offlineCount = Convert.ToInt32(ViewBag.OfflineCount ?? 0);
    var currentByDevice = ViewBag.CurrentScheduleByDevice as Dictionary<int, PlaybackSchedule> ?? new Dictionary<int, PlaybackSchedule>();
    var upcomingByDevice = ViewBag.UpcomingScheduleByDevice as Dictionary<int, PlaybackSchedule> ?? new Dictionary<int, PlaybackSchedule>();
    var playlists = ViewBag.Playlists as List<Playlist> ?? new List<Playlist>();
    var medias = ViewBag.Medias as List<Media> ?? new List<Media>();
    var utcNow = ViewBag.UtcNow as DateTime? ?? DateTime.UtcNow;
    var vietnamNow = ViewBag.VietnamNow as DateTime? ?? DateTime.UtcNow;
    ViewData["Title"] = "Thiết bị";
    var deviceQuery = ViewBag.DeviceQuery as string ?? string.Empty;
    var deviceStatus = ViewBag.DeviceStatus as string ?? string.Empty;
    var deviceSortBy = ViewBag.DeviceSortBy as string ?? "deviceCode";
    var deviceSortDir = ViewBag.DeviceSortDir as string ?? "asc";
    var onlineByDeviceCode = ViewBag.OnlineByDeviceCode as Dictionary<string, bool> ?? new Dictionary<string, bool>();
    var deviceKpis = new List<KpiViewModel>
    {
        new() { Key = "total", Label = "Tổng thiết bị", Value = totalDevices.ToString(), Description = "Đã liên kết", Icon = "bi-pc-display", Tone = "primary" },
        new() { Key = "online", Label = "Đang online", Value = onlineCount.ToString(), Description = "Sẵn sàng phát", Icon = "bi-wifi", Tone = "success" },
        new() { Key = "offline", Label = "Ngoại tuyến", Value = offlineCount.ToString(), Description = "Cần kiểm tra", Icon = "bi-power", Tone = "danger" }
    };

    string VietnamDate(DateTime utcDate) => utcDate.AddHours(7).ToString("dd/MM/yyyy");
    string DateRangeText(PlaybackSchedule schedule) => VietnamDate(schedule.StartDate) == VietnamDate(schedule.EndDate) ? VietnamDate(schedule.StartDate) : $"{VietnamDate(schedule.StartDate)} - {VietnamDate(schedule.EndDate)}";
    string TimeRangeText(PlaybackSchedule schedule) => $"{schedule.StartTime:hh\\:mm} - {schedule.EndTime:hh\\:mm}";
}

<link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />

<div class="devices-page">
  <section class="surface-card devices-toolbar">
    <div class="devices-toolbar-head">
      <div class="devices-toolbar-title">
        <span class="devices-toolbar-icon"><i class="bi bi-hdd-network"></i></span>
        <div>
          <h2>Quản lý thiết bị</h2>
          <p>Theo dõi trạng thái, vị trí và lịch phát trên từng thiết bị.</p>
        </div>
      </div>
      <button type="button" class="btn-primary devices-add-btn" onclick="showAddModal()"><i class="bi bi-plus-lg"></i>Thêm thiết bị</button>
    </div>

    <form method="get" action="/portal/devices" id="deviceFilterForm" class="devices-filter-form">
      <div class="search-box"><i class="bi bi-search"></i><input type="text" name="q" value="@deviceQuery" placeholder="Tìm kiếm theo mã/vị trí..." /></div>
      <select class="btn-soft fx-soft" name="status" onchange="document.getElementById('deviceFilterForm').submit()">
        <option value="" selected="@(string.IsNullOrWhiteSpace(deviceStatus))">Tất cả trạng thái</option>
        <option value="online" selected="@(deviceStatus == "online")">Trực tuyến</option>
        <option value="offline" selected="@(deviceStatus == "offline")">Ngoại tuyến</option>
      </select>
      <select class="btn-soft fx-soft" name="sortBy" onchange="document.getElementById('deviceFilterForm').submit()">
        <option value="deviceCode" selected="@(deviceSortBy == "deviceCode")">Mã thiết bị</option>
        <option value="lastSeen" selected="@(deviceSortBy == "lastSeen")">Lần hoạt động cuối</option>
      </select>
      <select class="btn-soft fx-soft" name="sortDir" onchange="document.getElementById('deviceFilterForm').submit()">
        <option value="asc" selected="@(deviceSortDir == "asc")">Tăng dần</option>
        <option value="desc" selected="@(deviceSortDir == "desc")">Giảm dần</option>
      </select>
      <button type="submit" class="u-hidden" aria-hidden="true">submit</button>
    </form>
  </section>

  <div class="devices-kpi-wrap">
    @await Html.PartialAsync("~/Views/Shared/Components/_KpiCards.cshtml", deviceKpis)
  </div>

  <section class="surface-card device-section devices-library-section">
    <header class="device-section-head">
      <div>
        <h2><i class="bi bi-pc-display"></i>Thiết bị đã liên kết</h2>
        <p>Hiển thị @Model.Count thiết bị theo bộ lọc hiện tại.</p>
      </div>
      <span class="pill-counter">@Model.Count thiết bị</span>
    </header>

@if (!Model.Any())
{
    <div class="empty-box devices-empty-box">
      <i class="bi bi-phone"></i>
      <span>Chưa có thiết bị phù hợp.</span>
      <button type="button" class="btn-primary devices-empty-action" onclick="showAddModal()"><i class="bi bi-plus-lg"></i>Thêm thiết bị</button>
    </div>
}
else
{
  <div class="device-grid">
    @foreach (var device in Model)
    {
      var isOnline = onlineByDeviceCode.GetValueOrDefault(device.DeviceCode);
      var currentSchedule = currentByDevice.ContainsKey(device.Id) ? currentByDevice[device.Id] : null;
      var upcomingSchedule = upcomingByDevice.ContainsKey(device.Id) ? upcomingByDevice[device.Id] : null;
      var locationText = string.IsNullOrWhiteSpace(device.Location) ? "Chưa có vị trí" : device.Location;
      var currentScheduleText = currentSchedule?.Name ?? "Chưa có";
      var upcomingScheduleText = upcomingSchedule?.Name ?? "Chưa có";
      var lastSeenVietnam = device.LastSeen.HasValue ? vietnamNow.Add(device.LastSeen.Value - utcNow).ToString("dd/MM/yyyy HH:mm") : "Chưa có";
      <article class="device-card device-card-compact fx-card @(isOnline ? "device-card-online" : "device-card-offline")">
        <header class="device-card-head">
          <div class="device-name">
            <span class="device-icon"><i class="bi bi-phone"></i></span>
            <span>
              <strong>@device.DeviceCode</strong>
              <small title="@locationText">@locationText</small>
            </span>
          </div>
          <span class="status-pill @(isOnline ? "online" : "offline")">@(isOnline ? "Online" : "Offline")</span>
        </header>

        <div class="device-status-list">
          <div class="device-status-item current">
            <span class="device-status-icon"><i class="bi bi-play-circle"></i></span>
            <div>
              <small>Đang phát</small>
              <strong class="@(currentSchedule == null ? "is-muted" : "")" title="@currentScheduleText">@currentScheduleText</strong>
            </div>
          </div>
          <div class="device-status-item upcoming">
            <span class="device-status-icon"><i class="bi bi-calendar2-week"></i></span>
            <div>
              <small>Sắp phát</small>
              <strong class="@(upcomingSchedule == null ? "is-muted" : "")" title="@upcomingScheduleText">@upcomingScheduleText</strong>
            </div>
          </div>
        </div>

        <footer class="device-card-footer">
          <span class="last-active" title="Hoạt động cuối: @lastSeenVietnam"><i class="bi bi-activity"></i>@lastSeenVietnam</span>
          <div class="device-actions">
            <button type="button" class="btn-primary" onclick="openQuickPlay(@device.Id); return false;" title="Phát nhanh"><i class="bi bi-play-fill"></i>Phát</button>
            <button type="button" class="btn-outline icon-only" onclick="openDeviceDetail(@device.Id); return false;" title="Chi tiết" aria-label="Chi tiết thiết bị @device.DeviceCode"><i class="bi bi-info-circle"></i></button>
            <form method="post" action="/portal/devices/delete" class="u-inline">
              @Html.AntiForgeryToken()
              <input type="hidden" name="deviceId" value="@device.Id" />
              <button type="submit" class="btn-outline icon-only u-danger-text" title="Xóa" aria-label="Xóa thiết bị @device.DeviceCode" onclick="return confirm('Bạn có chắc muốn xóa thiết bị này?')"><i class="bi bi-trash3"></i></button>
            </form>
          </div>
        </footer>
      </article>
    }
  </div>
}
  </section>

@foreach (var device in Model)
{
  var currentSchedule = currentByDevice.ContainsKey(device.Id) ? currentByDevice[device.Id] : null;
  var upcomingSchedule = upcomingByDevice.ContainsKey(device.Id) ? upcomingByDevice[device.Id] : null;
  var isOnline = onlineByDeviceCode.GetValueOrDefault(device.DeviceCode);
  var lastSeenVietnam = device.LastSeen.HasValue ? vietnamNow.Add(device.LastSeen.Value - utcNow).ToString("dd/MM/yyyy HH:mm") : "Chưa có";
  <div class="modal-overlay u-hidden" id="deviceDetail-@device.Id">
    <div class="modal modal-wide detail-modal device-detail-modal">
      <div class="detail-modal-header">
        <div class="detail-title-group">
          <span class="detail-title-icon device"><i class="bi bi-phone"></i></span>
          <div>
            <h3 class="modal-title">@device.DeviceCode</h3>
            <p class="detail-subtitle">Trạng thái thiết bị và lịch phát liên quan.</p>
          </div>
        </div>
        <button class="modal-close" type="button" onclick="closeDeviceDetail(@device.Id)" aria-label="Đóng"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="modal-body">
        <div class="detail-summary-grid">
          <section class="detail-panel">
            <div class="detail-panel-head">
              <span><i class="bi bi-info-circle"></i></span>
              <h3>Thông tin thiết bị</h3>
            </div>
            <div class="detail-fact-list">
              <div class="detail-fact"><span>Mã thiết bị</span><strong>@device.DeviceCode</strong></div>
              <div class="detail-fact"><span>Vị trí</span><strong>@(device.Location ?? "Chưa có")</strong></div>
              <div class="detail-fact"><span>Trạng thái</span><strong class="detail-status @(isOnline ? "active" : "danger")">@(isOnline ? "Đang online" : "Ngoại tuyến")</strong></div>
              <div class="detail-fact"><span>Lần hoạt động cuối</span><strong>@lastSeenVietnam</strong></div>
            </div>
          </section>
          <section class="detail-panel">
            <div class="detail-panel-head">
              <span><i class="bi bi-broadcast"></i></span>
              <h3>Đang phát</h3>
            </div>
          @if (currentSchedule == null)
          {
            <div class="detail-empty-state"><i class="bi bi-broadcast-pin"></i><span>Chưa có schedule đang phát.</span></div>
          }
          else
          {
            <div class="detail-schedule-summary">
              <strong>@currentSchedule.Name</strong>
              <div class="detail-chip-row">
                <span class="detail-chip primary"><i class="bi bi-calendar3"></i>@DateRangeText(currentSchedule)</span>
                <span class="detail-chip"><i class="bi bi-clock"></i>@TimeRangeText(currentSchedule)</span>
              </div>
            </div>
            <div class="detail-chip-row u-mt-075">
              @foreach (var item in currentSchedule.Items.OrderBy(i => i.OrderIndex))
              {
                <span class="detail-chip media">#@(item.OrderIndex + 1) @item.Media.FileName</span>
              }
            </div>
          }
          </section>
        </div>

        <section class="detail-panel detail-panel-wide u-mt-1">
          <div class="detail-panel-head">
            <span><i class="bi bi-hourglass-split"></i></span>
            <h3>Sắp phát</h3>
          </div>
        @if (upcomingSchedule == null)
        {
          <div class="detail-empty-state"><i class="bi bi-calendar-event"></i><span>Chưa có schedule sắp tới.</span></div>
        }
        else
        {
          <div class="detail-schedule-summary">
            <strong>@upcomingSchedule.Name</strong>
            <div class="detail-chip-row">
              <span class="detail-chip primary"><i class="bi bi-calendar3"></i>@DateRangeText(upcomingSchedule)</span>
              <span class="detail-chip"><i class="bi bi-clock"></i>@TimeRangeText(upcomingSchedule)</span>
            </div>
          </div>
          <div class="detail-chip-row u-mt-075">
            @foreach (var item in upcomingSchedule.Items.OrderBy(i => i.OrderIndex))
            {
              <span class="detail-chip media">#@(item.OrderIndex + 1) @item.Media.FileName</span>
            }
          </div>
        }
        </section>
      </div>
    </div>
  </div>
}

<div class="modal-overlay u-hidden" id="addModal">
  <div class="modal">
    <div class="modal-header">
      <h3 class="modal-title">Thêm thiết bị bằng mã liên kết</h3>
      <button class="modal-close" onclick="hideAddModal()">&times;</button>
    </div>
    <form method="post" action="/portal/devices">
      @Html.AntiForgeryToken()
      <div class="form-group">
        <label class="form-label">Mã liên kết</label>
        <input type="text" name="claimCode" id="claimCodeInput" class="form-input" placeholder="VD: 483920" inputmode="numeric" maxlength="6" pattern="[0-9]{6}" required />
        <div class="text-sm text-muted u-mt-045">Mã 6 số hiển thị trên app sau khi đăng ký thiết bị.</div>
      </div>
      <div class="flex gap-2 u-mt-125">
        <button type="button" class="btn btn-secondary flex-1" onclick="hideAddModal()">Hủy</button>
        <button type="submit" class="btn btn-primary flex-1">Liên kết</button>
      </div>
    </form>
  </div>
</div>

<div class="modal-overlay u-hidden" id="quickPlayModal">
  <div class="modal modal-wide">
    <div class="modal-header">
      <div>
        <h3 class="modal-title">Phát nhanh trên device</h3>
        <p class="text-sm text-muted" id="quickPlayDeviceInfo">Chọn nội dung rồi bấm phát.</p>
      </div>
      <button class="modal-close" type="button" onclick="hideQuickPlayModal()">&times;</button>
    </div>

    <form method="post" action="/portal/schedules/create" id="quickPlayForm">
      @Html.AntiForgeryToken()
      <input type="hidden" name="actionType" value="immediate" />
      <input type="hidden" name="DeviceIds" id="quickPlayDeviceId" />
      <input type="hidden" name="Name" id="quickPlayName" />
      <input type="hidden" name="StartDate" id="quickPlayStartDate" />
      <input type="hidden" name="EndDate" id="quickPlayEndDate" />
      <input type="hidden" name="StartTime" id="quickPlayStartTime" />
      <input type="hidden" name="EndTime" id="quickPlayEndTime" />
      <input type="hidden" name="PlaylistId" id="quickPlayPlaylistId" />

      <div class="quick-play-tabs">
        <button type="button" class="quick-play-tab active" id="quickPlayMediaTab" onclick="switchQuickPlaySource('media')">Video</button>
        <button type="button" class="quick-play-tab" id="quickPlayPlaylistTab" onclick="switchQuickPlaySource('playlist')">Danh sách phát</button>
      </div>

      <div id="quickPlayMediaPanel">
        @if (!medias.Any())
        {
          <div class="empty-state u-padding-1 u-mt-1">
            <p>Chưa có video trong kho.</p>
          </div>
        }
        else
        {
          <div class="quick-play-list">
            @foreach (var media in medias)
            {
              <label class="quick-play-item">
                <input type="checkbox" name="MediaIds" value="@media.Id" data-quickplay-media />
                <div>
                  <div class="quick-play-title">@media.FileName</div>
                  <div class="quick-play-subtitle">@((media.FileSize / 1024 / 1024).ToString()) MB</div>
                </div>
              </label>
            }
          </div>
        }
      </div>

      <div id="quickPlayPlaylistPanel" class="u-hidden">
        @if (!playlists.Any())
        {
          <div class="empty-state u-padding-1 u-mt-1">
            <p>Chưa có playlist nào.</p>
          </div>
        }
        else
        {
          <div class="quick-play-list">
            @foreach (var playlist in playlists)
            {
              var playlistItems = playlist.Items.OrderBy(i => i.OrderIndex).ToList();
              <label class="quick-play-item">
                <input type="radio" name="playlistChoice" value="@playlist.Id" data-quickplay-playlist />
                <div>
                  <div class="quick-play-title">@playlist.Name</div>
                  <div class="quick-play-subtitle">@playlistItems.Count video(s)</div>
                </div>
              </label>
            }
          </div>
        }
      </div>

      <div class="flex gap-2 u-mt-125">
        <button type="button" class="btn btn-secondary flex-1" onclick="hideQuickPlayModal()">Hủy</button>
        <button type="submit" class="btn btn-primary flex-1" id="quickPlaySubmitBtn">Phát ngay</button>
      </div>
    </form>
  </div>
</div>

</div>

<script>
  let quickPlaySource = 'media';
  const quickPlayDeviceData = {};

  function showAddModal() { document.getElementById('addModal').style.display = 'flex'; }
  function hideAddModal() { document.getElementById('addModal').style.display = 'none'; }
  function openDeviceDetail(id) { document.getElementById('deviceDetail-' + id).style.display = 'flex'; }
  function closeDeviceDetail(id) { document.getElementById('deviceDetail-' + id).style.display = 'none'; }

  document.getElementById('claimCodeInput')?.addEventListener('input', function () {
    this.value = this.value.replace(/[^0-9]/g, '').slice(0, 6);
  });

  function setQuickPlayDateTime() {
    const now = new Date();
    const year = String(now.getFullYear());
    const month = String(now.getMonth() + 1).padStart(2, '0');
    const day = String(now.getDate()).padStart(2, '0');
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(Math.min(now.getMinutes(), 58)).padStart(2, '0');

    document.getElementById('quickPlayStartDate').value = year + '-' + month + '-' + day;
    document.getElementById('quickPlayEndDate').value = year + '-' + month + '-' + day;
    document.getElementById('quickPlayStartTime').value = hours + ':' + minutes;
    document.getElementById('quickPlayEndTime').value = '23:59';
  }

  function clearQuickPlaySelection() {
    document.querySelectorAll('#quickPlayForm input[name="MediaIds"]').forEach(input => input.checked = false);
    document.querySelectorAll('#quickPlayForm input[data-quickplay-playlist]').forEach(input => input.checked = false);
    document.getElementById('quickPlayPlaylistId').value = '';
  }

  function switchQuickPlaySource(source) {
    quickPlaySource = source;
    document.getElementById('quickPlayMediaPanel').style.display = source === 'media' ? 'block' : 'none';
    document.getElementById('quickPlayPlaylistPanel').style.display = source === 'playlist' ? 'block' : 'none';
    document.getElementById('quickPlayMediaTab').classList.toggle('active', source === 'media');
    document.getElementById('quickPlayPlaylistTab').classList.toggle('active', source === 'playlist');

    if (source === 'media') {
      document.getElementById('quickPlayPlaylistId').value = '';
      document.querySelectorAll('#quickPlayForm input[data-quickplay-playlist]').forEach(input => input.checked = false);
    } else {
      document.querySelectorAll('#quickPlayForm input[name="MediaIds"]').forEach(input => input.checked = false);
    }
  }

  function openQuickPlay(deviceId) {
    const device = quickPlayDeviceData[deviceId];
    if (!device) return;

    document.getElementById('quickPlayDeviceId').value = deviceId;
    document.getElementById('quickPlayName').value = 'Phát nhanh - ' + device.code + ' - ' + new Date().toISOString().replace(/[-:T]/g, '').slice(0, 12);
    document.getElementById('quickPlayDeviceInfo').textContent = device.code + ' | ' + device.location;
    setQuickPlayDateTime();
    clearQuickPlaySelection();
    switchQuickPlaySource('media');
    document.getElementById('quickPlayModal').style.display = 'flex';
  }

  function hideQuickPlayModal() {
    document.getElementById('quickPlayModal').style.display = 'none';
  }

  document.querySelectorAll('#quickPlayForm input[data-quickplay-playlist]').forEach(input => {
    input.addEventListener('change', function () {
      if (!this.checked) return;
      document.getElementById('quickPlayPlaylistId').value = this.value;
      document.querySelectorAll('#quickPlayForm input[name="MediaIds"]').forEach(item => item.checked = false);
      switchQuickPlaySource('playlist');
    });
  });

  document.getElementById('quickPlayForm').addEventListener('submit', function (e) {
    const mediaIds = Array.from(document.querySelectorAll('#quickPlayForm input[name="MediaIds"]:checked')).map(input => input.value);
    const playlistId = document.getElementById('quickPlayPlaylistId').value;

    if (quickPlaySource === 'media') {
      document.getElementById('quickPlayPlaylistId').value = '';
      if (!mediaIds.length) {
        e.preventDefault();
        window.showToast('Chọn ít nhất một video.', 'error');
      }
      return;
    }

    if (!playlistId) {
      e.preventDefault();
      window.showToast('Chọn playlist trước khi phát.', 'error');
      return;
    }
  });

  document.querySelectorAll('#quickPlayForm input[name="MediaIds"]').forEach(input => {
    input.addEventListener('change', function () {
      if (!this.checked) return;
      document.getElementById('quickPlayPlaylistId').value = '';
      document.querySelectorAll('#quickPlayForm input[data-quickplay-playlist]').forEach(item => item.checked = false);
      switchQuickPlaySource('media');
    });
  });

  @foreach (var device in Model)
  {
    <text>quickPlayDeviceData[@device.Id] = { code: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(device.DeviceCode)), location: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(device.Location ?? "Chưa có vị trí")) };</text>
  }
</script>

<style>
  .quick-play-tabs { display:flex; gap:.5rem; margin-top: 1rem; flex-wrap: wrap; }
  .quick-play-tab { border: 1px solid var(--border); background: var(--muted); color: var(--muted-foreground); border-radius: 999px; padding: .45rem .9rem; font-size: .85rem; font-weight: 600; cursor: pointer; }
  .quick-play-tab.active { background: var(--primary); color: var(--primary-foreground); border-color: var(--primary); }
  .quick-play-list { display: grid; gap: .5rem; margin-top: 1rem; max-height: 42vh; overflow: auto; padding-right: .25rem; }
  .quick-play-item { display:flex; align-items:flex-start; gap:.75rem; border: 1px solid var(--border); border-radius: var(--radius); padding: .75rem .9rem; cursor: pointer; background: var(--card); }
  .quick-play-item input { margin-top: .2rem; }
  .quick-play-title { font-weight: 600; color: var(--foreground); }
  .quick-play-subtitle { font-size: .78rem; color: var(--muted-foreground); margin-top: .15rem; }
  .device-card-actions { display:grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap:.5rem; padding-top: 0.75rem; margin-top: 0.75rem; border-top: 1px solid var(--border); }
  .device-card-actions form { margin: 0; }
  .device-card-actions .btn { width: 100%; }
  @@media (max-width: 768px) { .device-card-actions { grid-template-columns: 1fr; } }
</style>
