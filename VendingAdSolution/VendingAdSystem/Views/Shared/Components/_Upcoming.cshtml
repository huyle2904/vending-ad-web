@using VendingAdSystem.Application.DTOs
@model PlaylistViewModel?
@{
  var ctaUrl = Model?.CtaUrl ?? "/portal/schedules";
  var emptyMessage = string.IsNullOrWhiteSpace(Model?.EmptyMessage) || Model.EmptyMessage == "Chưa có dữ liệu"
    ? "Chưa có danh sách phát sắp tới."
    : Model.EmptyMessage;
}

<article class="surface-card schedule-panel schedule-panel-upcoming">
  <header class="surface-head schedule-panel-head">
    <div>
      <h2><span class="status-dot tone-warning"></span>Sắp phát</h2>
      <p>Danh sách phát sắp tới trên các thiết bị</p>
    </div>
    <span class="schedule-state-badge upcoming"><i class="bi bi-hourglass-split"></i>Chờ lịch</span>
  </header>

@if (Model == null || Model.IsEmpty)
{
  <div class="empty-box schedule-empty-box"><i class="bi bi-calendar-event"></i><span>@emptyMessage</span></div>
}
else
{
  <div class="playlist-item playlist-focus">
    <div class="playlist-thumb-wrap">
      <img src="@(string.IsNullOrWhiteSpace(Model.ThumbnailUrl) ? "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=600&q=60" : Model.ThumbnailUrl)" alt="preview" />
      <span><i class="bi bi-clock"></i>Sắp phát</span>
    </div>
    <div class="playlist-copy">
      <h3>@Model.Name</h3>
      <div class="meta-row">
        <span><i class="bi bi-calendar3"></i>@Model.DateText</span>
        <span><i class="bi bi-clock"></i>@Model.TimeText</span>
      </div>
      <div class="playlist-badge-row">
        <span class="mini-badge"><i class="bi bi-display"></i>@Model.DeviceCode</span>
        <span class="count-badge">@Model.VideoCount video</span>
      </div>
    </div>
  </div>
}

  <a class="cta-link" href="@ctaUrl">Xem tất cả sắp phát <i class="bi bi-arrow-right"></i></a>
</article>
