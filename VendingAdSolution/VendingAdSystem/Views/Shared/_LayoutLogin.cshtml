<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@ViewData["Title"] — VendAD</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Manrope:wght@600;700;800&display=swap" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/ui-components.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/ui-effects.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/lib/bootstrap-icons/bootstrap-icons.min.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/login-redesign.css" asp-append-version="true" />
  <style>
    html, body {
      margin: 0;
      padding: 0;
      min-height: 100%;
      background: linear-gradient(180deg, #f7faff 0%, #eef4ff 52%, #f9fbff 100%);
    }
  </style>
</head>
<body class="login-layout-body">
  @RenderBody()
</body>
</html>
