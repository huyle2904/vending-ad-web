@inject Microsoft.AspNetCore.Antiforgery.IAntiforgery Antiforgery
@{
    var antiforgeryTokens = Antiforgery.GetAndStoreTokens(Context);
    var principal = Context.User;
    var sessionUserId = Context.Session.GetInt32("UserId");
    var adminEmail = Context.Session.GetString("AdminEmail")
        ?? (principal.IsInRole("Admin") ? principal.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value : null);
    var userEmail = Context.Session.GetString("UserEmail")
        ?? (principal.IsInRole("User") ? principal.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value : null);
    var isPortalUser = (sessionUserId != null && sessionUserId > 0) || principal.IsInRole("User");
    var isAdmin = !string.IsNullOrEmpty(adminEmail) || principal.IsInRole("Admin");
    var topDisplayName = Context.Session.GetString("UserDisplayName") ?? principal.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? userEmail ?? (adminEmail ?? "Người dùng");
    var topRoleLabel = isAdmin ? "Quản trị viên" : "Người dùng";
    var topAvatar = string.IsNullOrWhiteSpace(topDisplayName) ? "U" : topDisplayName.Trim().Substring(0,1).ToUpper();
    var currentUrl = Context.Request.Path.ToString().ToLower();
    var homeUrl = isAdmin && !isPortalUser ? "/admin" : "/portal/dashboard";
    var pageTitle = ViewData["Title"]?.ToString() ?? "VendAD";
    var toastMessages = new List<Dictionary<string, string>>();

    if (TempData["Success"] is string successMessage && !string.IsNullOrWhiteSpace(successMessage))
        toastMessages.Add(new Dictionary<string, string> { ["type"] = "success", ["message"] = successMessage });
    if (TempData["Error"] is string errorMessage && !string.IsNullOrWhiteSpace(errorMessage))
        toastMessages.Add(new Dictionary<string, string> { ["type"] = "error", ["message"] = errorMessage });
    if (TempData["Warning"] is string warningMessage && !string.IsNullOrWhiteSpace(warningMessage))
        toastMessages.Add(new Dictionary<string, string> { ["type"] = "warning", ["message"] = warningMessage });
}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="request-verification-token" content="@antiforgeryTokens.RequestToken" />
  <title>@pageTitle | VendAD</title>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&display=swap" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/ui-components.css" asp-append-version="true" />
  <link rel="stylesheet" href="~/css/ui-effects.css" asp-append-version="true" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</head>
<body class="app-shell-body">
  <aside class="sidebar">
    <a class="sidebar-logo" href="@homeUrl" aria-label="VendAD">
      <span class="sidebar-logo-badge"><i class="bi bi-display"></i></span>
      <span class="sidebar-logo-text">
        <strong>VendAD</strong>
        <small>Content CMS</small>
      </span>
    </a>
    <nav class="sidebar-nav">
      @if (isPortalUser)
      {
        <div class="nav-section">
          <div class="nav-section-title">Vận hành</div>
          <a href="/portal/dashboard" class="nav-item @(currentUrl.StartsWith("/portal/dashboard") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-speedometer2"></i></span>
            <span class="nav-label">Bảng điều khiển</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/portal/schedules" class="nav-item @(currentUrl.StartsWith("/portal/schedules") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-calendar3"></i></span>
            <span class="nav-label">Lịch phát</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/portal/devices" class="nav-item @(currentUrl.StartsWith("/portal/devices") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-phone"></i></span>
            <span class="nav-label">Thiết bị</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/portal/device-wall" class="nav-item @(currentUrl.StartsWith("/portal/device-wall") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-display"></i></span>
            <span class="nav-label">Màn hình thiết bị</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
        </div>
        <div class="nav-section">
          <div class="nav-section-title">Nội dung</div>
          <a href="/portal/videos" class="nav-item @(currentUrl.StartsWith("/portal/videos") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-film"></i></span>
            <span class="nav-label">Video</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/portal/playlist" class="nav-item @(currentUrl.StartsWith("/portal/playlist") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-card-checklist"></i></span>
            <span class="nav-label">Danh sách phát</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
        </div>
      }
      @if (isAdmin)
      {
        <div class="nav-section">
          <div class="nav-section-title">Quản trị</div>
          <a href="/admin" class="nav-item @((currentUrl == "/admin" || currentUrl == "/admin/") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-speedometer2"></i></span>
            <span class="nav-label">Thống kê</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/admin/users" class="nav-item @(currentUrl.Contains("/admin/users") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-people"></i></span>
            <span class="nav-label">Tài khoản</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/admin/devices" class="nav-item @(currentUrl.Contains("/admin/devices") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-phone"></i></span>
            <span class="nav-label">Thiết bị</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
        </div>
        <div class="nav-section">
          <div class="nav-section-title">Nội dung</div>
          <a href="/admin/videos" class="nav-item @(currentUrl.Contains("/admin/videos") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-film"></i></span>
            <span class="nav-label">Video</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/admin/playlists" class="nav-item @(currentUrl.Contains("/admin/playlists") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-card-checklist"></i></span>
            <span class="nav-label">Danh sách phát</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
          <a href="/admin/schedules" class="nav-item @(currentUrl.Contains("/admin/schedules") ? "active" : "")">
            <span class="nav-icon"><i class="bi bi-calendar3"></i></span>
            <span class="nav-label">Lịch phát</span>
            <i class="bi bi-chevron-right nav-caret"></i>
          </a>
        </div>
      }
    </nav>

    <div class="sidebar-footer">
      <div class="sidebar-user-card">
        <span class="avatar">@topAvatar</span>
        <span class="user-details">
          <strong class="user-name">@topDisplayName</strong>
          <small class="user-role">@topRoleLabel</small>
        </span>
      </div>
    </div>
  </aside>
  <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="closeAppSidebar()"></div>

  <main class="main-content">
    <div class="shared-top-header">
      <button type="button" class="mobile-nav-toggle" aria-label="Mở menu" onclick="toggleAppSidebar(event)">
        <i class="bi bi-list"></i>
      </button>
      <div class="shared-header-title">
        <span>@topRoleLabel</span>
        <strong>@pageTitle</strong>
      </div>
      <div class="dashboard-actions">
        <button class="icon-btn" aria-label="Thông báo"><i class="bi bi-bell"></i><span class="dot">3</span></button>
        <div class="profile-menu" id="globalProfileMenu">
          <button type="button" class="profile-btn" onclick="toggleGlobalProfileMenu(event)">
            <span class="avatar">@topAvatar</span>
            <span class="profile-meta"><strong>@topDisplayName</strong><small>@topRoleLabel</small></span>
            <i class="bi bi-chevron-down"></i>
          </button>
          <div class="profile-dropdown" id="globalProfileDropdown">
            <a href="/profile" class="profile-dropdown-item"><i class="bi bi-person"></i>Tài khoản</a>
            <a href="/settings" class="profile-dropdown-item"><i class="bi bi-gear"></i>Cài đặt</a>
            <form method="post" action="/account/logout" class="profile-dropdown-form">
              @Html.AntiForgeryToken()
              <button type="submit" class="profile-dropdown-item danger"><i class="bi bi-box-arrow-right"></i>Đăng xuất</button>
            </form>
          </div>
        </div>
      </div>
    </div>
    <div class="app-shell">


      @RenderBody()
    </div>
  </main>
  <div class="toast-container" id="toastContainer" aria-live="polite" aria-atomic="true"></div>
  <script>
    (function () {
      window.getRequestVerificationToken = function () {
        return document.querySelector('meta[name="request-verification-token"]')?.content || '';
      };

      const messages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(toastMessages));
      const container = document.getElementById('toastContainer');

      window.showToast = function (message, type) {
        if (!message || !container) return;
        const toast = document.createElement('div');
        toast.className = 'toast toast-' + (type || 'success');
        toast.innerHTML = '<div class="toast-body"><div class="toast-title">' + toastTitle(type) + '</div><div class="toast-message"></div></div><button type="button" class="toast-close" aria-label="Đóng">&times;</button>';
        toast.querySelector('.toast-message').textContent = message;
        toast.querySelector('.toast-close').addEventListener('click', function () { dismissToast(toast); });
        container.appendChild(toast);
        requestAnimationFrame(function () { toast.classList.add('toast-show'); });
        setTimeout(function () { dismissToast(toast); }, 4500);
      };

      function toastTitle(type) {
        if (type === 'error') return 'Có lỗi xảy ra';
        if (type === 'warning') return 'Cần chú ý';
        return 'Thành công';
      }

      function dismissToast(toast) {
        toast.classList.remove('toast-show');
        setTimeout(function () { toast.remove(); }, 180);
      }

      function closeCustomSelects(except) {
        document.querySelectorAll(".custom-select-wrap.open").forEach(function (wrap) {
          if (wrap !== except) wrap.classList.remove("open");
        });
      }

      function enhanceCustomSelect(select) {
        if (!select || select.multiple || select.dataset.customSelectEnhanced === "true") return;

        const wrap = document.createElement("span");
        wrap.className = "custom-select-wrap" + (select.classList.contains("btn-soft") || select.classList.contains("fx-soft") ? " compact" : "");
        select.parentNode.insertBefore(wrap, select);
        wrap.appendChild(select);
        select.classList.add("custom-select-native");
        select.dataset.customSelectEnhanced = "true";

        const button = document.createElement("button");
        button.type = "button";
        button.className = "custom-select-button";
        button.setAttribute("aria-haspopup", "listbox");
        button.setAttribute("aria-expanded", "false");

        const label = document.createElement("span");
        label.className = "custom-select-label";
        const caret = document.createElement("span");
        caret.className = "custom-select-caret";
        caret.innerHTML = '<i class="bi bi-chevron-down"></i>';
        button.appendChild(label);
        button.appendChild(caret);

        const menu = document.createElement("div");
        menu.className = "custom-select-menu";
        menu.setAttribute("role", "listbox");

        wrap.appendChild(button);
        wrap.appendChild(menu);

        function selectedOption() {
          return select.options[select.selectedIndex] || select.options[0];
        }

        function updateLabel() {
          const option = selectedOption();
          label.textContent = option ? option.textContent : "";
          Array.from(menu.children).forEach(function (item) {
            item.classList.toggle("selected", item.dataset.value === select.value);
            item.setAttribute("aria-selected", item.dataset.value === select.value ? "true" : "false");
          });
        }

        function chooseOption(option) {
          if (!option || option.disabled) return;
          select.value = option.value;
          updateLabel();
          wrap.classList.remove("open");
          button.setAttribute("aria-expanded", "false");
          select.dispatchEvent(new Event("change", { bubbles: true }));
        }

        Array.from(select.options).forEach(function (option) {
          const item = document.createElement("button");
          item.type = "button";
          item.className = "custom-select-option" + (option.disabled ? " disabled" : "");
          item.textContent = option.textContent;
          item.dataset.value = option.value;
          item.setAttribute("role", "option");
          item.addEventListener("click", function (event) {
            event.preventDefault();
            chooseOption(option);
          });
          menu.appendChild(item);
        });

        button.addEventListener("click", function (event) {
          event.stopPropagation();
          const isOpen = wrap.classList.contains("open");
          closeCustomSelects(wrap);
          wrap.classList.toggle("open", !isOpen);
          button.setAttribute("aria-expanded", !isOpen ? "true" : "false");
        });

        button.addEventListener("keydown", function (event) {
          if (event.key === "Escape") {
            wrap.classList.remove("open");
            button.setAttribute("aria-expanded", "false");
          }
          if (event.key === "Enter" || event.key === " ") {
            event.preventDefault();
            button.click();
          }
        });

        select.addEventListener("change", updateLabel);
        updateLabel();
      }

      window.refreshCustomSelects = function () {
        document.querySelectorAll("select:not([data-native-select])").forEach(enhanceCustomSelect);
      };

      messages.forEach(function (item) { window.showToast(item.message, item.type); });
      window.refreshCustomSelects();
      window.toggleAppSidebar = function (event) {
        event.stopPropagation();
        document.querySelector(".sidebar")?.classList.toggle("open");
        document.getElementById("sidebarBackdrop")?.classList.toggle("open");
      };
      window.closeAppSidebar = function () {
        document.querySelector(".sidebar")?.classList.remove("open");
        document.getElementById("sidebarBackdrop")?.classList.remove("open");
      };
      window.toggleGlobalProfileMenu = function (event) {
        event.stopPropagation();
        document.getElementById("globalProfileDropdown")?.classList.toggle("open");
      };
      document.addEventListener("click", function(e){
        var menu=document.getElementById("globalProfileMenu");
        var drop=document.getElementById("globalProfileDropdown");
        if(menu && drop && !menu.contains(e.target)) drop.classList.remove("open");
        if (!e.target.closest(".custom-select-wrap")) closeCustomSelects();
      });

    })();
  </script>
</body>
</html>
