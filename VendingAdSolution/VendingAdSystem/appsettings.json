{
  "DatabaseProvider": "Sqlite",
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "EnsureCreatedOnStartup": true
  },
  "Seed": {
    "EnableDemoData": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=vendingad.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379"
  },
  "DevicePresence": {
    "OnlineTtlSeconds": 90,
    "DbWriteIntervalSeconds": 60
  },
  "MobileRateLimiting": {
    "WindowSeconds": 60,
    "HeartbeatPermitLimit": 10,
    "PlaybackStatePermitLimit": 30
  },
  "RabbitMQ": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "",
    "Password": "",
    "ExchangeName": "vendingad.events"
  },
  "AllowedHosts": "*"
}
