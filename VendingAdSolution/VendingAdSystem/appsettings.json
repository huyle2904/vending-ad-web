{
  "DatabaseProvider": "Sqlite",
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "EnsureCreatedOnStartup": true,
    "ResetOnStartup": false,
    "ResetSchemaOnStartup": false
  },
  "Seed": {
    "EnableDemoData": false,
    "AllowDemoDataOutsideDevelopment": false
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=vendingad.db"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/vendingad-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "VendingAdCMS"
    }
  },
  "Redis": {
    "Enabled": false,
    "ConnectionString": "localhost:6379"
  },
  "DevicePresence": {
    "OnlineTtlSeconds": 90,
    "DbWriteIntervalSeconds": 60
  },
  "MobileRateLimiting": {
    "WindowSeconds": 60,
    "DeviceInfoPermitLimit": 20,
    "HeartbeatPermitLimit": 10,
    "PlaybackStatePermitLimit": 30,
    "PlaylistPermitLimit": 30
  },
  "VideoValidation": {
    "FfprobeEnabled": true,
    "RequireFfprobe": false,
    "FfprobePath": "ffprobe",
    "ProbeTimeoutSeconds": 10,
    "AllowedVideoCodecs": [ "h264", "hevc", "vp8", "vp9", "av1" ]
  },
  "RabbitMQ": {
    "Enabled": false,
    "HostName": "localhost",
    "Port": 5672,
    "UserName": "",
    "Password": "",
    "ExchangeName": "vendingad.events"
  },
  "AllowedHosts": "*"
}
